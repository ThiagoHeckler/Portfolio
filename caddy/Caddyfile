# ============================================================
# Caddyfile — thiagoheckler.com.br
# HTTPS automático via Let's Encrypt (HTTP challenge).
# Adicionar um projeto novo = copiar um bloco de 3 linhas.
# ============================================================

{
	email thiag0224@hotmail.com   # avisos de renovação de certificado
}

# ---------- Snippet de log de acesso ----------
# Importar com "import log_acesso" em cada site que deve registrar acessos.
(log_acesso) {
	log {
		output file /var/log/caddy/access.log {
			roll_size     10MiB   # gira o arquivo ao atingir esse tamanho
			roll_keep     10      # mantém no máximo 10 arquivos girados
			roll_keep_for 2160h   # ~90 dias
		}
		format console
	}
}

# ---------- Site principal (estático, sem JVM) ----------
thiagoheckler.com.br {
	import log_acesso
	root * /srv/site
	file_server
	encode gzip

	# Cache agressivo p/ assets, nenhum p/ HTML
	@static path *.css *.js *.png *.jpg *.svg *.webp *.woff2
	header @static Cache-Control "public, max-age=31536000, immutable"
}

# Redireciona www -> raiz
www.thiagoheckler.com.br {
	redir https://thiagoheckler.com.br{uri} permanent
}

# ---------- Projetos (subdomínios) ----------
siscontabil.thiagoheckler.com.br {
	import log_acesso
	reverse_proxy siscontabil:8080
}

tasks.thiagoheckler.com.br {
	import log_acesso
	reverse_proxy task-api:8080
}

links.thiagoheckler.com.br {
	import log_acesso
	reverse_proxy link-shortener:8080
}

estoque.thiagoheckler.com.br {
	import log_acesso
	reverse_proxy estoque-dashboard:8080
}

chat.thiagoheckler.com.br {
	import log_acesso
	# WebSocket funciona sem config extra — o Caddy faz upgrade sozinho
	reverse_proxy chat:8080
}

auth.thiagoheckler.com.br {
	import log_acesso
	reverse_proxy auth-service:8080
}

pizzaria.thiagoheckler.com.br {
	import log_acesso
	reverse_proxy pizzaria:8080
}
