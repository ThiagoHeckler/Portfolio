{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/content/**",
              "components/primitives/**",
              "ui_kits/portfolio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArchStat'] > JSXAttribute > JSXIdentifier[name!=/^(?:stat|label|key|ref|className|style|children)$/]",
        "message": "<ArchStat> doesn't accept that prop. Declared props: stat, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|db|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, db."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='db'] > Literal[value!=/^(?:pg|mongo|accent)$/]",
        "message": "<Badge> db must be one of 'pg' | 'mongo' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|href|variant|size|disabled|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, href, variant, size, disabled, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|lead|actions|key|ref|className|style|children)$/]",
        "message": "<ContactBox> doesn't accept that prop. Declared props: eyebrow, title, lead, actions."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='DbBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:db|label|key|ref|className|style|children)$/]",
        "message": "<DbBadge> doesn't accept that prop. Declared props: db, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='DbBadge'] > JSXAttribute[name.name='db'] > Literal[value!=/^(?:pg|mongo|accent)$/]",
        "message": "<DbBadge> db must be one of 'pg' | 'mongo' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='WhyBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:db|children|key|ref|className|style|children)$/]",
        "message": "<WhyBlock> doesn't accept that prop. Declared props: db, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='WhyBlock'] > JSXAttribute[name.name='db'] > Literal[value!=/^(?:pg|mongo|both)$/]",
        "message": "<WhyBlock> db must be one of 'pg' | 'mongo' | 'both'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|logoSrc|key|ref|className|style|children)$/]",
        "message": "<Wordmark> doesn't accept that prop. Declared props: href, logoSrc."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "ArchStat": {
        "replaces": []
